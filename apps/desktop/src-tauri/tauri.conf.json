{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deckdown",
  "version": "0.1.0",
  "identifier": "dev.deckdown.client",
  "build": {
    "beforeDevCommand": "pnpm --filter @deckdownjs/web dev",
    "beforeBuildCommand": "pnpm -w build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deckdown",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
