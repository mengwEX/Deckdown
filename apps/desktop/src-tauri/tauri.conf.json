{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deckdown",
  "version": "0.1.0",
  "identifier": "dev.deckdown.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @deckdown/web dev",
    "beforeBuildCommand": "pnpm --filter @deckdown/web build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Deckdown",
        "width": 1440,
        "height": 960,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
