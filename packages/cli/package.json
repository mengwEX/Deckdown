{
  "name": "@deckdownjs/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "deckdown": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "deckdown": "node dist/index.js"
  },
  "dependencies": {
    "@deckdownjs/compiler": "workspace:*",
    "@deckdownjs/exporter": "workspace:*",
    "@deckdownjs/parser": "workspace:*",
    "@deckdownjs/schema": "workspace:*",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
