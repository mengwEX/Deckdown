      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mengwEX/Deckdown.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/mengwEX/Deckdown#readme",
  "bugs": {
    "url": "https://github.com/mengwEX/Deckdown/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
