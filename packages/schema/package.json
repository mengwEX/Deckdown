{
  "name": "@deckdownjs/schema",
  "version": "0.1.0",
  "description": "Shared TypeScript contracts and validation helpers for Deckdown .dd decks.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
