{
  "name": "@deckdownjs/renderer",
  "version": "0.1.0",
  "description": "Safe HTML rendering and standalone document helpers for Deckdown .dd decks.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mengwEX/Deckdown.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://github.com/mengwEX/Deckdown#readme",
  "bugs": {
    "url": "https://github.com/mengwEX/Deckdown/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deckdownjs/schema": "workspace:^",
    "parse5": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
